<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- Welcome page -->
    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>

    <!-- Login Servlet (role-based) -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.water.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet (user self-registration) -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.water.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.water.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Usage / Billing Servlet (admin) -->
    <servlet>
        <servlet-name>UsageServlet</servlet-name>
        <servlet-class>com.water.UsageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UsageServlet</servlet-name>
        <url-pattern>/usage</url-pattern>
    </servlet-mapping>

</web-app>
